

class Box:
    def __init__(self, x0: float, y0: float, z0: float, Lx: float, Ly: float, Lz: float) -> None: ...

    def cx(self) -> float: ...

    def cy(self) -> float: ...

    def cz(self) -> float: ...

    def contains(self, x: float, y: float, z: float) -> bool: ...

    def volume(self) -> float: ...

    @property
    def x0(self) -> float: ...

    @x0.setter
    def x0(self, arg: float, /) -> None: ...

    @property
    def y0(self) -> float: ...

    @y0.setter
    def y0(self, arg: float, /) -> None: ...

    @property
    def z0(self) -> float: ...

    @z0.setter
    def z0(self, arg: float, /) -> None: ...

    @property
    def Lx(self) -> float: ...

    @Lx.setter
    def Lx(self, arg: float, /) -> None: ...

    @property
    def Ly(self) -> float: ...

    @Ly.setter
    def Ly(self, arg: float, /) -> None: ...

    @property
    def Lz(self) -> float: ...

    @Lz.setter
    def Lz(self, arg: float, /) -> None: ...

class Domain:
    def __init__(self, domain_box: Box, mass: float, W: float, molecule_size: float) -> None: ...

    def generateParticles(self, n_density: float, T: float) -> None: ...

    def generateMesh(self, hx: float, hy: float, hz: float) -> None: ...

    def makeCellList(self) -> None: ...

    def updateCellList(self) -> None: ...

    def applyPeriodicBoundaries(self, px: bool, py: bool, pz: bool) -> None: ...

    def moveParticles(self, dt: float) -> None: ...

    def collideParticles(self, dt: float) -> None: ...

    def saveXYZ(self, file_name: str) -> None: ...

    def printStatsHeader(self) -> None: ...

    def printStats(self, time: float) -> None: ...
